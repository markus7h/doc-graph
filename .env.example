# Container läuft auf myubuntu (RTX 5080), teilt sich das Ollama von paperless-ai.
# paperless-ollama mappt Port 11434 auf den Host -> host.docker.internal.
OLLAMA_HOST=http://host.docker.internal:11434

# Geteiltes mistral: paperless-ai + ai-rem nutzen dasselbe Modell mit num_ctx=32768.
# Gleiches Modell + gleicher num_ctx => kein Modell-Reload beim Consumer-Wechsel.
# Extraktion mit mistral erst testen (Graph via graph_view prüfen); liefert sie
# matschige Relationen, auf qwen3:14b wechseln (kostet dann VRAM-Reload).
LLM_MODEL=mistral-small3.2:24b
LLM_NUM_CTX=32768

# bge-m3: mehrsprachig (Deutsch!), 1024 Dim — identisch zu paperless-ai.
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Parallele LLM-Calls beim Indexieren. 2 ist für eine RTX 5080 konservativ.
MAX_ASYNC=2

# Paperless-NGX (Dokumentquelle): volle URL zur laufenden Instanz + API-Token.
PAPERLESS_URL=http://host.docker.internal:8000
PAPERLESS_TOKEN=dein_paperless_api_token

# Host, unter dem der Graph-Viewer vom Browser erreichbar ist.
PUBLIC_HOST=myubuntu
