# Container läuft auf myubuntu (RTX 5080), nutzt den geteilten llm-stack
# (Repo llm-stack) über das externe Docker-Netz llm-net.
# LLM: Alias 'llm' zeigt immer auf das AKTIVE Chat-Modell (Normalbetrieb
# llm-mistral, während des Ingests llm-qwen — der Swap wechselt per stop/start,
# Docker-DNS löst nur laufende Container auf). OpenAI-kompatibles /v1.
# Kontext ist server-seitig via -c gesetzt, kein LLM_NUM_CTX mehr nötig.
LLM_BASE_URL=http://llm:11434/v1
LLM_MODEL=mistral-small3.2:24b

# bge-m3: mehrsprachig (Deutsch!), 1024 Dim — identisch zu paperless-ai. Läuft
# auf einem eigenen CPU-llama-server (llm-embed), separater Port.
EMBED_BASE_URL=http://llm-embed:11435/v1
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Parallele LLM-Calls beim Indexieren. 2 ist für eine RTX 5080 konservativ.
MAX_ASYNC=2

# Paperless-NGX (Dokumentquelle): volle URL zur laufenden Instanz + API-Token.
# LAN-interne NGX via DNS 'paperless' (self-signed Cert -> Client mit verify=False).
# Kann leer bleiben: compose-Default ist https://paperless/.
PAPERLESS_URL=https://paperless/
PAPERLESS_TOKEN=dein_paperless_api_token

# Host, unter dem der Graph-Viewer vom Browser erreichbar ist.
PUBLIC_HOST=myubuntu
