# Container läuft auf myubuntu (RTX 5080), teilt sich die llama-server-Container
# von paperless-ai über das gemeinsame Docker-Netz paperless-ai_default.
# LLM: mistral via paperless-llama (GPU, OpenAI-kompatibles /v1/chat/completions).
# Kontext (32768) ist server-seitig via -c gesetzt, kein LLM_NUM_CTX mehr nötig.
# Extraktion mit mistral erst testen (Graph via graph_view prüfen); liefert sie
# matschige Relationen, auf ein größeres/anderes Modell wechseln (LLM_MODEL +
# Command-Flag im paperless-llama-Container anpassen, kostet dann VRAM-Reload).
LLM_BASE_URL=http://paperless-llama:11434/v1
LLM_MODEL=mistral-small3.2:24b

# bge-m3: mehrsprachig (Deutsch!), 1024 Dim — identisch zu paperless-ai. Läuft
# auf einem eigenen CPU-llama-server (paperless-llama-embed), separater Port.
EMBED_BASE_URL=http://paperless-llama-embed:11435/v1
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Parallele LLM-Calls beim Indexieren. 2 ist für eine RTX 5080 konservativ.
MAX_ASYNC=2

# Paperless-NGX (Dokumentquelle): volle URL zur laufenden Instanz + API-Token.
PAPERLESS_URL=http://host.docker.internal:8000
PAPERLESS_TOKEN=dein_paperless_api_token

# Host, unter dem der Graph-Viewer vom Browser erreichbar ist.
PUBLIC_HOST=myubuntu
